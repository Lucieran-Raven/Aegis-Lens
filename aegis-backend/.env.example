# Aegis Lens Backend - Environment Variables
# Copy this file to .env and fill in the actual values for your deployment

# ============================================
# Server Configuration
# ============================================
# Port the backend server listens on
# Required: No (default: 8443)
SERVER_PORT=8443

# Environment mode - development or production
# Required: No (default: release in production builds)
GIN_MODE=release

# Log level - debug, info, warn, error
# Required: No (default: info)
LOG_LEVEL=info

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Required: No (default: https://yourdomain.com,https://app.yourdomain.com)
# Example: http://localhost:3000,https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://app.yourdomain.com

# ============================================
# Redis Configuration
# ============================================
# Redis server address
# Required: No (default: localhost:6379)
REDIS_ADDR=localhost:6379

# Alternative Redis configuration (used in docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# TimescaleDB / PostgreSQL Configuration
# ============================================
# TimescaleDB connection string
# Required: No (default: postgres://localhost/aegis?sslmode=disable)
TIMESCALE_CONN=postgres://localhost/aegis?sslmode=disable

# Alternative database configuration (used in docker-compose)
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis_user
POSTGRES_PASSWORD=change_this_in_production

# ============================================
# TLS / SSL Configuration
# ============================================
# Path to TLS certificate file
# Required: Yes for production HTTPS
TLS_CERT_PATH=/etc/ssl/certs/aegis-backend.crt

# Path to TLS private key file
# Required: Yes for production HTTPS
TLS_KEY_PATH=/etc/ssl/private/aegis-backend.key

# ============================================
# Security Configuration
# ============================================
# Session time-to-live in seconds
# Required: No (default: 300 - 5 minutes)
SESSION_TTL_SECONDS=300

# Maximum allowed clock skew between client and server in seconds
# Required: No (default: 5)
MAX_CLOCK_SKEW_SECONDS=5

# ============================================
# Rate Limiting Configuration
# ============================================
# Maximum requests per minute for verify endpoint per IP
# Required: No (default: 100)
RATE_LIMIT_VERIFY_PER_MINUTE=100

# Maximum requests per minute for session init endpoint per IP
# Required: No (default: 10)
RATE_LIMIT_SESSION_INIT_PER_MINUTE=10
