# Aegis Lens v2.0 - Environment Variables Configuration
# Copy this file to .env and fill in the actual values for your environment

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Server Configuration
SERVER_PORT=8443
GIN_MODE=release
LOG_LEVEL=info

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=your_redis_password_here

# TimescaleDB / PostgreSQL Configuration
TIMESCALE_CONN=postgres://aegis_user:your_db_password_here@localhost:5432/aegis?sslmode=require
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis_user
POSTGRES_PASSWORD=your_db_password_here

# TLS/SSL Configuration (Required for production)
TLS_CERT_PATH=/etc/ssl/certs/aegis-backend.crt
TLS_KEY_PATH=/etc/ssl/private/aegis-backend.key

# CORS Configuration
# Comma-separated list of allowed origins (e.g., https://yourdomain.com,https://app.yourdomain.com)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Session TTL (in minutes)
SESSION_TTL_MINUTES=5

# Clock Skew Tolerance (in seconds)
MAX_CLOCK_SKEW_SECONDS=30

# ============================================================================
# SDK CONFIGURATION (if running SDK as a service)
# ============================================================================

NODE_ENV=production
SDK_PORT=3000
API_ENDPOINT=https://api.yourdomain.com
